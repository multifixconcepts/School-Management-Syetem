# ============================================
# DATABASE CONFIGURATION
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://your_user:your_password@db-school8:5432/your_db

# ============================================
# REDIS CONFIGURATION
# ============================================
# Format: redis://HOST:PORT/DATABASE_NUMBER
REDIS_URL=redis://redis-school8:6379/0

# ============================================
# APPLICATION SECURITY
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# CORS SETTINGS
# ============================================
BACKEND_CORS_ORIGINS=["http://localhost:8000", "http://school8.edunaija.online", "https://school8.edunaija.online"]

# ============================================
# POSTGRESQL DIRECT VARIABLES
# ============================================
POSTGRES_DB=school8_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here
